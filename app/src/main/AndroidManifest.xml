<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".TrackRateApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrackRate"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:resizeableActivity="true"
            android:theme="@style/Theme.TrackRate.NoActionBar"
            tools:targetApi="24">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:resizeableActivity="true"
            android:theme="@style/Theme.TrackRate.NoActionBar"
            tools:targetApi="24" />
        <activity
            android:name=".DetailActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".SubmitActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".SubmissionsActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".ModerationOptionsActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".ModerationActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".ModerationReviewActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".LabelsActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".AdminUsersActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".EditProfileActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".ListsActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
        <activity
            android:name=".ListDetailActivity"
            android:exported="false"
            android:label="@string/blank"
            android:theme="@style/Theme.TrackRate.NoActionBar" />
    </application>

</manifest>