<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_branding_root"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/toolbar_logo_full"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/toolbar_logo_full_height"
        android:layout_gravity="center_vertical"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:src="@drawable/logo_full"
        android:visibility="gone"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/toolbar_title_row"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/toolbar_logo_icon"
            android:layout_width="@dimen/toolbar_logo_icon_width"
            android:layout_height="@dimen/toolbar_logo_icon_height"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo_icon"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/toolbar_title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.AppCompat.Widget.ActionBar.Title"
            android:textColor="@android:color/white" />
    </LinearLayout>
</FrameLayout>
