<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TrackRate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.TrackRate.Purple" parent="Theme.TrackRate">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
    </style>

    <style name="Theme.TrackRate.Blue" parent="Theme.TrackRate">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <style name="Theme.TrackRate.Red" parent="Theme.TrackRate">
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorPrimaryVariant">@color/accent_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>
</resources>
