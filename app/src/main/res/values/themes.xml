<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TrackRate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.TrackRate.Purple" parent="Theme.TrackRate">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_purple_dark</item>
    </style>

    <style name="Theme.TrackRate.Blue" parent="Theme.TrackRate">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue_dark</item>
    </style>

    <style name="Theme.TrackRate.Red" parent="Theme.TrackRate">
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorPrimaryVariant">@color/accent_red_dark</item>
    </style>

    <style name="Theme.TrackRate.NoActionBar" parent="Theme.TrackRate">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.TrackRate.Purple.NoActionBar" parent="Theme.TrackRate.Purple">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.TrackRate.Blue.NoActionBar" parent="Theme.TrackRate.Blue">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.TrackRate.Red.NoActionBar" parent="Theme.TrackRate.Red">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.TrackRate.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.TrackRate.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />
</resources>
