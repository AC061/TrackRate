# Copia a .env y ajusta valores
DATABASE_URL=postgresql+psycopg://trackrate:trackrate@localhost:5432/trackrate
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://10.0.2.2:9000
# Emulador Android: 10.0.2.2 apunta al localhost del PC.
# Dispositivo físico: usa la IP LAN de tu PC, p. ej. http://192.168.1.10:9000

CORS_ORIGINS=*
